{
  "info": {
    "name": "TP02 - FHIR to openEHR (Final)",
    "description": "Coleção que demonstra o fluxo completo de ponta-a-ponta pedido no enunciado.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Obter Token JWT (Login admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"jwt_token\", jsonData.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "username",
              "value": "admin",
              "type": "text"
            },
            {
              "key": "password",
              "value": "1234",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/token",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "token"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Criar Paciente com N. Utente (SNS)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "var patient_id = jsonData.id.replace('pat-', '');",
              "pm.environment.set(\"patient_id\", patient_id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"numero_sns\": \"123456789\",\n    \"nome\": \"Helena Oliveira\",\n    \"genero\": \"feminino\",\n    \"telecom\": [\n        {\"tipo\": \"telemóvel\", \"valor\": \"912345678\"}\n    ],\n    \"contacto\": [\n        {\"nome\": \"Familiar\", \"telecom\": [{\"tipo\": \"telemóvel\", \"valor\": \"912345678\"}], \"endereco\": []}\n    ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/Patient",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Patient"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. Criar Profissional de Saúde (Cédula)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "var prac_id = jsonData.id.replace('prac-', '');",
              "pm.environment.set(\"practitioner_id\", prac_id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"cedula\": \"C-98765\",\n    \"nome\": \"Dr. Rui Silva\",\n    \"especialidade\": \"Cardiologia\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/Practitioner",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Practitioner"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Criar Consulta (Encounter)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"paciente_id\": {{patient_id}},\n    \"practitioner_id\": {{practitioner_id}},\n    \"status\": \"finished\",\n    \"classe_code\": \"AMB\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/Encounter",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Encounter"
          ]
        }
      },
      "response": []
    },
    {
      "name": "5. Enviar Saturação (Dispositivo -> FHIR)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Este pedido vai diretamente ao HAPI FHIR.",
              "// Isso faz o FHIR disparar um Webhook para a nossa API!"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/fhir+json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceType\": \"Observation\",\n  \"status\": \"final\",\n  \"code\": {\n    \"coding\": [\n      {\n        \"system\": \"http://loinc.org\",\n        \"code\": \"59408-5\",\n        \"display\": \"Oxygen saturation in Arterial blood\"\n      }\n    ]\n  },\n  \"subject\": {\n    \"reference\": \"Patient/pat-{{patient_id}}\"\n  },\n  \"performer\": [\n    {\n      \"reference\": \"Practitioner/prac-{{practitioner_id}}\"\n    }\n  ],\n  \"effectiveDateTime\": \"2024-05-17T14:30:00Z\",\n  \"valueQuantity\": {\n    \"value\": 98.5,\n    \"unit\": \"%\",\n    \"system\": \"http://unitsofmeasure.org\",\n    \"code\": \"%\"\n  }\n}"
        },
        "url": {
          "raw": "{{fhir_url}}/Observation",
          "host": [
            "{{fhir_url}}"
          ],
          "path": [
            "Observation"
          ]
        }
      },
      "response": []
    },
    {
      "name": "5.5 Obter Sinais Vitais (AQL Direta EHRbase)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"q\": \"SELECT obs/name/value AS tipo, obs/data[at0002]/events[at0003]/data[at0001]/items[at0004]/value/magnitude AS valor_temp_freq_peso, obs/data[at0001]/events[at0006]/data[at0003]/items[at0004]/value/magnitude AS valor_sistolica, obs/data[at0001]/events[at0002]/data[at0003]/items[at0006]/value/numerator AS valor_saturacao, obs/data[at0001]/events[at0002]/data[at0003]/items[at0004]/value/magnitude AS valor_generico, c/context/start_time/value AS data, e/ehr_id/value AS ehr_id FROM EHR e CONTAINS COMPOSITION c CONTAINS OBSERVATION obs WHERE e/ehr_status/subject/external_ref/id/value = 'pat-{{patient_id}}' AND e/ehr_status/subject/external_ref/namespace = 'pt-sns-utente' ORDER BY c/context/start_time/value DESC LIMIT 200\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8085/ehrbase/rest/openehr/v1/query/aql",
          "host": [
            "127.0.0.1"
          ],
          "port": "8085",
          "path": [
            "ehrbase",
            "rest",
            "openehr",
            "v1",
            "query",
            "aql"
          ]
        },
        "description": "Executa a mesma query AQL poderosa que o nosso Streamlit faz para ir buscar os dados diretamente ao repositório openEHR!"
      },
      "response": []
    },
    {
      "name": "5.5. Obter EHR ID do Paciente (Pesquisa Direta)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic YWRtaW4tdXNlcjpSZXF1aXJlbWVudFBhc3N3b3Jk"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://127.0.0.1:8085/ehrbase/rest/openehr/v1/ehr?subject_id=pat-{{patient_id}}&subject_namespace=pt_sns_utente",
          "host": [
            "127.0.0.1:8085"
          ],
          "path": [
            "ehrbase",
            "rest",
            "openehr",
            "v1",
            "ehr"
          ],
          "query": [
            {
              "key": "subject_id",
              "value": "pat-{{patient_id}}"
            },
            {
              "key": "subject_namespace",
              "value": "pt.sns.utente"
            }
          ]
        },
        "description": "Faz a pesquisa diretamente ao EHRbase para descobrir o EHR ID gerado para o nosso paciente FHIR!"
      },
      "response": []
    },
    {
      "name": "6. Obter Sinais Vitais do EHRbase (Desafio Extra)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/ehr/COLOQUE_AQUI_O_ID_DO_EHR/observations",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "ehr",
            "COLOQUE_AQUI_O_ID_DO_EHR",
            "observations"
          ]
        }
      },
      "response": []
    },
    {
      "name": "7. Enviar Vários Sinais Vitais em Lote (FHIR Bundle)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resourceType\": \"Bundle\",\n  \"type\": \"transaction\",\n  \"entry\": [\n    {\n      \"resource\": {\n        \"resourceType\": \"Observation\",\n        \"status\": \"final\",\n        \"code\": {\"coding\": [{\"system\": \"http://loinc.org\", \"code\": \"8310-5\"}]},\n        \"subject\": {\"reference\": \"Patient/pat-{{patient_id}}\"},\n        \"performer\": [{\"reference\": \"Practitioner/prac-{{practitioner_id}}\"}],\n        \"effectiveDateTime\": \"2024-05-18T10:00:00Z\",\n        \"valueQuantity\": {\"value\": 37.2, \"unit\": \"Cel\", \"system\": \"http://unitsofmeasure.org\", \"code\": \"Cel\"}\n      }\n    },\n    {\n      \"resource\": {\n        \"resourceType\": \"Observation\",\n        \"status\": \"final\",\n        \"code\": {\"coding\": [{\"system\": \"http://loinc.org\", \"code\": \"8867-4\"}]},\n        \"subject\": {\"reference\": \"Patient/pat-{{patient_id}}\"},\n        \"performer\": [{\"reference\": \"Practitioner/prac-{{practitioner_id}}\"}],\n        \"effectiveDateTime\": \"2024-05-18T10:00:00Z\",\n        \"valueQuantity\": {\"value\": 72, \"unit\": \"/min\", \"system\": \"http://unitsofmeasure.org\", \"code\": \"/min\"}\n      }\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/Bundle",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Bundle"
          ]
        },
        "description": "Desafio Extra: Suporta um FHIR Bundle com múltiplas Observations numa única chamada, processando-as em lote."
      },
      "response": []
    },
    {
      "name": "8. Pesquisar Pacientes (GET)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/Patient?name=Helena",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Patient"
          ],
          "query": [
            {
              "key": "name",
              "value": "Helena"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "9. Pesquisar Profissionais (GET)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/Practitioner?especialidade=Cardiologia",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Practitioner"
          ],
          "query": [
            {
              "key": "especialidade",
              "value": "Cardiologia"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "10. Obter Observations do Paciente (GET)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/Observation?patient={{patient_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Observation"
          ],
          "query": [
            {
              "key": "patient",
              "value": "{{patient_id}}"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "11. Pesquisar Consultas (GET Encounter)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/Encounter?patient={{patient_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "Encounter"
          ],
          "query": [
            {
              "key": "patient",
              "value": "{{patient_id}}"
            }
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "fhir_url",
      "value": "http://localhost:9090/fhir",
      "type": "string"
    }
  ]
}